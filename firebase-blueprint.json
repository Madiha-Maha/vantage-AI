{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "string" },
        "socials": {
          "type": "object",
          "properties": {
            "linkedin": { "type": "string" },
            "github": { "type": "string" },
            "portfolio": { "type": "string" }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "theme": { "type": "string", "enum": ["dark", "light", "system"] },
            "notifications": { "type": "boolean" },
            "recordingEnabled": { "type": "boolean" },
            "privacyMode": { "type": "boolean" },
            "biometricAnalysis": { "type": "boolean" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Session": {
      "title": "Session",
      "description": "Interview session records",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "role": { "type": "string" },
        "difficulty": { "type": "string" },
        "overallScore": { "type": "number" },
        "feedback": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "answer": { "type": "string" },
              "transcript": { "type": "string" },
              "analysis": {
                "type": "object",
                "properties": {
                  "score": { "type": "number" },
                  "confidence": { "type": "number" },
                  "speakingSpeed": { "type": "number" },
                  "keywordsFound": { "type": "array", "items": { "type": "string" } },
                  "tips": { "type": "array", "items": { "type": "string" } },
                  "eyeContactScore": { "type": "number" }
                }
              }
            }
          }
        }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile data and settings"
    },
    "users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "User interview history"
    }
  }
}
