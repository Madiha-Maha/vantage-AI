rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Common helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.updatedAt == request.time &&
             data.keys().hasAll(['name', 'email', 'title', 'bio', 'avatar', 'skills', 'experience', 'socials', 'settings', 'updatedAt']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200 &&
             data.title is string && data.title.size() <= 200 &&
             data.bio is string && data.bio.size() <= 1000 &&
             data.avatar is string && data.avatar.size() <= 1000 &&
             data.skills is list && data.skills.size() <= 50 &&
             data.experience is string && data.experience.size() <= 2000 &&
             data.socials is map && data.socials.size() <= 10 &&
             data.settings is map && data.settings.size() >= 5;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['date', 'role', 'difficulty', 'overallScore', 'feedback', 'questions']) &&
             data.keys().size() == 6 &&
             data.date == request.time &&
             data.role is string && data.role.size() <= 200 &&
             data.difficulty is string && data.difficulty.size() <= 50 &&
             data.overallScore is number &&
             data.feedback is string && data.feedback.size() <= 5000 &&
             data.questions is list && data.questions.size() <= 20 &&
             (data.questions.size() == 0 || data.questions[0] is map);
    }

    // 3. Path Variable Hardening & Explicit Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
      
      match /sessions/{sessionId} {
        // ID Poisoning Guard
        allow get: if isOwner(userId) && isValidId(sessionId);
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidId(sessionId) && isValidSession(incoming());
        
        // Tiered Identity logic: Sessions are mostly immutable once submitted, but we allow deletion
        allow delete: if isOwner(userId);
      }
    }
  }
}
